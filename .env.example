# Bible Study Bot — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# Telegram — NEW bot via @BotFather (separate from Chief of Staff bot)
TELEGRAM_BOT_TOKEN=your_new_bible_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Google Gemini — free tier ($0)
# Get at: https://aistudio.google.com → "Get API key"
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic — Phase 3 journal synthesis only (~$0.30/month)
# Reuse your existing API key from the Chief of Staff system
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Crossway ESV API — passage text for devotions + study docs (free, non-commercial)
# Get a key at: https://api.esv.org/  (sign up → create an API application)
ESV_API_KEY=your_esv_api_key_here

# Gmail SMTP — for email distribution list
# App Password (NOT your main Gmail password)
# Set up at: myaccount.google.com/apppasswords
GMAIL_ADDRESS=daniel.chiefofstaff@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password_here
